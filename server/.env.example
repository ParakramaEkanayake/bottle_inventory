# --- Local MongoDB (used during development) ---
# MONGO_URI=mongodb://127.0.0.1:27017/bottle_inventory

# --- MongoDB Atlas (cloud, used for production) ---
# Get this from Atlas: Database -> Connect -> Drivers -> copy the connection string,
# then replace <username>, <password>, and add /bottle_inventory before the "?"
MONGO_URI=mongodb+srv://bottle1234:bottle1234@cluster0.xat4ck6.mongodb.net/bottle_inventory?appName=Cluster0
   JWT_SECRET=someOtherRandomString
PORT=5000

# The URL(s) of your deployed frontend. Comma-separate multiple values.
# Keep localhost in here too while you're still testing locally.
CLIENT_URL=http://localhost:5173,https://your-app.vercel.app
